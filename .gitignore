# Rust build output
/target/

# Build artifacts (cross-compiled binaries, COFF objects, etc.)
*.o
*.obj
*.exe
*.dll
*.lib
*.pdb
*.exp

# Local BOF arg buffers (binary, generated per-run)
examples/*.bin
examples/*_args.bin

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db

# Vendored third-party BOF kits (cloned locally, not part of this repo)
/Extension-Kit/

# Local goal/task scratch files
goal.md

# SQLite runtime database (created by the Go core next to the exe)
*.db
*.db-shm
*.db-wal
